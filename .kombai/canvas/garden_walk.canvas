    "var_0a2026e10b09": {
      "type": "variant",
      "label": "Immersive Papercraft Walk (Z-axis)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 1380,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "\n<div class=\"h-screen w-full bg-[#F0F8FF] overflow-hidden relative font-sans text-[#111111]\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;700&family=DM+Sans:wght@400;500;700&display=swap');\n        \n        :root {\n            --alice-blue: #F0F8FF;\n            --cherry-blossom: #FFB7C5;\n            --malachite: #0BDA51;\n            --onyx: #111111;\n        }\n\n        .font-serif { font-family: 'Fraunces', serif; }\n        .font-sans { font-family: 'DM Sans', sans-serif; }\n\n        /* Custom cursor for playful feel */\n        .custom-cursor {\n            width: 12px;\n            height: 12px;\n            background: var(--cherry-blossom);\n            border-radius: 50%;\n            position: fixed;\n            pointer-events: none;\n            z-index: 9999;\n            mix-blend-mode: multiply;\n            box-shadow: 0 0 15px var(--cherry-blossom);\n        }\n\n        /* Papercraft shadow */\n        .paper-shadow {\n            filter: drop-shadow(0 20px 40px rgba(0,0,0,0.25));\n        }\n\n        .text-glow {\n            text-shadow: 0 0 40px rgba(255, 255, 255, 0.4);\n        }\n\n        /* Prevent scrollbars while maintaining sticky/animations */\n        body {\n            overflow: hidden;\n        }\n\n        .scene-container {\n            transform-origin: center center;\n        }\n\n        .drifting-leaf {\n            pointer-events: none;\n            position: absolute;\n            z-index: 45;\n        }\n    </style>\n\n    \n    <div id=\"cursor\" class=\"custom-cursor hidden md:block\" data-kid=\"2\"></div>\n\n    \n    <div class=\"fixed top-8 right-8 z-[100] flex items-center gap-4 bg-white/90 backdrop-blur-xl px-5 py-2.5 rounded-full border border-black/5 shadow-xl\" data-kid=\"3\">\n        <div class=\"w-9 h-9 flex items-center justify-center bg-black text-white rounded-full cursor-pointer hover:scale-110 transition-transform shadow-lg\" data-kid=\"4\">\n            <i class=\"ti ti-player-play text-xs ml-0.5\" data-kid=\"5\"></i>\n        </div>\n        <div class=\"flex flex-col\" data-kid=\"6\">\n            <span class=\"text-[10px] font-bold uppercase tracking-widest text-black\" data-kid=\"7\">Nature Ambience</span>\n            <span class=\"text-[8px] font-medium text-black/40 uppercase tracking-tight\" data-kid=\"8\">Forest Morning</span>\n        </div>\n    </div>\n\n    \n    <div id=\"viewport\" class=\"relative w-full h-full scene-container\" data-kid=\"9\">\n        \n        \n        <section id=\"hero\" class=\"absolute inset-0 z-10 flex flex-col items-center justify-center overflow-hidden\" data-kid=\"10\">\n            \n            <div class=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1672451539634-922acbbe96f1?auto=format&w=1920&q=80&fit=crop')] bg-cover bg-center\" data-kid=\"11\">\n                <div class=\"absolute inset-0 bg-gradient-to-b from-transparent to-[#F0F8FF]/40\" data-kid=\"12\"></div>\n            </div>\n\n            \n            <div class=\"absolute inset-0 pointer-events-none flex justify-between z-20 -mx-[5%] overflow-hidden\" data-kid=\"13\">\n                <img src=\"https://images.unsplash.com/photo-1609347018332-f6812692f287?auto=format&w=1400&q=80\" class=\"h-full w-auto object-cover opacity-40 paper-shadow translate-x-[-15%] scale-110\" style=\"transform: scaleX(-1);\" alt=\"Frame Left\" decoding=\"async\" loading=\"lazy\" data-kid=\"14\">\n                <img src=\"https://images.unsplash.com/photo-1609347018332-f6812692f287?auto=format&w=1400&q=80\" class=\"h-full w-auto object-cover opacity-40 paper-shadow translate-x-[15%] scale-110\" alt=\"Frame Right\" decoding=\"async\" loading=\"lazy\" data-kid=\"15\">\n            </div>\n\n            \n            <div id=\"hero-content\" class=\"relative z-30 text-center px-6 max-w-4xl mx-auto\" data-kid=\"16\">\n                <h1 class=\"font-serif text-8xl md:text-[11rem] tracking-tighter leading-[0.8] mb-8 text-white drop-shadow-[0_15px_45px_rgba(0,0,0,0.6)]\" data-kid=\"17\">Come for<br data-kid=\"18\"><span class=\"text-[#FFB7C5] drop-shadow-[0_15px_30px_rgba(255,183,197,0.3)]\" data-kid=\"19\">a walk</span></h1>\n                <p class=\"font-sans text-xs md:text-base tracking-[0.6em] uppercase text-white mb-20 drop-shadow-2xl font-medium\" data-kid=\"20\">The garden is breathing, and so should you.</p>\n                <div class=\"flex flex-col items-center gap-8\" data-kid=\"21\">\n                    <div class=\"w-px h-32 bg-gradient-to-b from-white/0 via-white/40 to-[#FFB7C5]\" data-kid=\"22\"></div>\n                    <span class=\"text-xs font-black uppercase tracking-[0.4em] text-white/80 animate-pulse drop-shadow-lg\" data-kid=\"23\">Stay a moment</span>\n                </div>\n            </div>\n        </section>\n\n        \n        <section id=\"clearing\" class=\"absolute inset-0 z-5 flex flex-col items-center justify-center opacity-0 scale-[0.5] overflow-hidden bg-[#F0F8FF]\" data-kid=\"24\">\n             \n             <div class=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1741814581184-c07388cbc57c?auto=format&w=1920&q=80&fit=crop')] bg-cover bg-center\" data-kid=\"25\">\n                 <div class=\"absolute inset-0 bg-[#FFB7C5]/10 mix-blend-overlay\" data-kid=\"26\"></div>\n             </div>\n\n             \n             <div id=\"message-1\" class=\"relative z-10 w-full max-w-xl p-1 shadow-2xl rounded-[2.5rem] bg-gradient-to-br from-[#FFB7C5]/20 to-white/10 backdrop-blur-sm\" data-kid=\"27\">\n                <div class=\"bg-white rounded-[2.2rem] p-12 text-center border border-white/50\" data-kid=\"28\">\n                    <div class=\"mb-8 inline-flex items-center justify-center w-20 h-20 rounded-full bg-[#0BDA51]/10\" data-kid=\"29\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/solid-leaf.svg\" class=\"w-10 h-10\" style=\"filter: invert(47%) sepia(87%) saturate(3089%) hue-rotate(114deg) brightness(96%) contrast(101%);\" data-kid=\"30\">\n                    </div>\n                    <h2 class=\"font-serif text-5xl mb-6\" data-kid=\"31\">The air is fresh here.</h2>\n                    <p class=\"font-sans text-lg text-black/60 mb-10 leading-relaxed\" data-kid=\"32\">\n                        Take a deep breath. Can you hear the soft whisper of the cherry blossoms? They've been waiting for someone to listen.\n                    </p>\n                    <button id=\"btn-zoom-2\" class=\"group relative px-10 py-5 bg-black text-white rounded-full font-bold overflow-hidden transition-all active:scale-95\" data-kid=\"33\">\n                        <span class=\"relative z-10\" data-kid=\"34\">Continue deeper</span>\n                        <div class=\"absolute inset-0 bg-[#FFB7C5] translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out\" data-kid=\"35\"></div>\n                    </button>\n                </div>\n             </div>\n\n             \n             <div id=\"leaves-container\" class=\"absolute inset-0 pointer-events-none\" data-kid=\"36\"></div>\n        </section>\n\n        \n        <section id=\"deep-garden\" class=\"absolute inset-0 z-0 flex flex-col items-center justify-center opacity-0 scale-[0.5] overflow-hidden bg-black\" data-kid=\"37\">\n             \n             <div class=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1759306105972-9d4fc473f922?auto=format&w=1920&q=80&fit=crop')] bg-cover bg-center\" data-kid=\"38\">\n                <div class=\"absolute inset-0 bg-black/40\" data-kid=\"39\"></div>\n             </div>\n\n             \n             <div id=\"message-2-wrapper\" class=\"relative z-10\" data-kid=\"40\">\n                <div class=\"absolute top-[-50vh] left-1/2 w-px h-[50vh] bg-white/30\" data-kid=\"41\"></div>\n                <div id=\"message-2\" class=\"bg-white p-10 rounded-2xl shadow-[0_50px_100px_rgba(0,0,0,0.3)] max-w-sm text-center border-t-8 border-[#FFB7C5] transform-gpu\" data-kid=\"42\">\n                    <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/cherry-blossom.svg\" class=\"w-20 h-20 mx-auto mb-6\" data-kid=\"43\">\n                    <h3 class=\"font-serif text-3xl mb-4\" data-kid=\"44\">A gift for you.</h3>\n                    <p class=\"font-sans text-lg text-black/60 italic leading-relaxed\" data-kid=\"45\">\n                        \"In every walk with nature, one receives far more than he seeks.\"\n                    </p>\n                    <div class=\"mt-8 pt-8 border-t border-black/5 flex justify-center gap-6\" data-kid=\"46\">\n                        <div class=\"w-10 h-10 rounded-full bg-[#F0F8FF] flex items-center justify-center cursor-pointer hover:bg-[#FFB7C5] transition-colors\" data-kid=\"47\">\n                            <i class=\"ti ti-brand-instagram\" data-kid=\"48\"></i>\n                        </div>\n                        <div class=\"w-10 h-10 rounded-full bg-[#F0F8FF] flex items-center justify-center cursor-pointer hover:bg-[#FFB7C5] transition-colors\" data-kid=\"49\">\n                            <i class=\"ti ti-brand-x\" data-kid=\"50\"></i>\n                        </div>\n                    </div>\n                </div>\n             </div>\n\n             \n             <div class=\"absolute bottom-20 left-1/2 -translate-x-1/2 text-center pointer-events-none\" data-kid=\"51\">\n                <p class=\"font-sans text-[10px] text-white/40 uppercase tracking-[0.5em]\" data-kid=\"52\">The path ends here, but the journey continues.</p>\n             </div>\n        </section>\n\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"53\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"54\"></script>\n    <script type=\"module\" data-kid=\"55\">\n        import { animate, spring } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n        gsap.registerPlugin(ScrollTrigger);\n\n        // --- CUSTOM CURSOR ---\n        const cursor = document.getElementById('cursor');\n        window.addEventListener('mousemove', (e) => {\n            gsap.to(cursor, {\n                x: e.clientX - 10,\n                y: e.clientY - 10,\n                duration: 0.2,\n                ease: 'power2.out'\n            });\n        });\n\n        // --- LEAF GENERATOR ---\n        function createLeaf() {\n            const container = document.getElementById('leaves-container');\n            const leaf = document.createElement('img');\n            const types = ['delapouite/solid-leaf', 'lorc/falling-leaf', 'delapouite/ginkgo-leaf'];\n            const type = types[Math.floor(Math.random() * types.length)];\n            \n            leaf.src = `https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/${type}.svg`;\n            leaf.classList.add('drifting-leaf', 'w-6', 'h-6');\n            leaf.style.left = Math.random() * 100 + '%';\n            leaf.style.top = '-50px';\n            leaf.style.filter = `hue-rotate(${Math.random() * 30}deg) opacity(${0.3 + Math.random() * 0.4})`;\n            \n            container.appendChild(leaf);\n\n            gsap.to(leaf, {\n                y: '110vh',\n                x: (Math.random() - 0.5) * 400,\n                rotation: Math.random() * 720,\n                duration: 5 + Math.random() * 5,\n                ease: 'none',\n                onComplete: () => leaf.remove()\n            });\n        }\n\n        // --- CORE CAMERA ANIMATION ---\n        \n        // Initial Sequence: Hero to Clearing\n        window.addEventListener('load', () => {\n            const tl = gsap.timeline({ delay: 1 });\n\n            // Entrance of Hero Content\n            gsap.from('#hero-content', {\n                y: 50,\n                opacity: 0,\n                duration: 2,\n                ease: 'power4.out'\n            });\n\n            // Subtle floating effect for hero content\n            gsap.to('#hero-content', {\n                y: -15,\n                duration: 4,\n                ease: 'sine.inOut',\n                repeat: -1,\n                yoyo: true\n            });\n\n            // 5 Seconds Delay then ZOOM IN\n            gsap.delayedCall(5, () => {\n                const zoomIn = gsap.timeline();\n                \n                // Hero fades out and scales up (Immersive zoom)\n                zoomIn.to('#hero', {\n                    scale: 4,\n                    opacity: 0,\n                    duration: 4,\n                    ease: 'power3.inOut',\n                    pointerEvents: 'none'\n                });\n\n                // Clearing enters\n                zoomIn.to('#clearing', {\n                    opacity: 1,\n                    scale: 1,\n                    duration: 2.5,\n                    ease: 'power2.out',\n                }, '-=2');\n\n                // Reveal Message 1 with Circle Reveal or similar\n                zoomIn.from('#message-1', {\n                    scale: 0.8,\n                    opacity: 0,\n                    duration: 1.5,\n                    ease: 'back.out(1.7)',\n                    onStart: () => {\n                        // Start leaf storm\n                        setInterval(createLeaf, 400);\n                    }\n                }, '-=1');\n            });\n        });\n\n        // Interaction: Clearing to Deep Garden\n        document.getElementById('btn-zoom-2').addEventListener('click', () => {\n            const zoomDeeper = gsap.timeline();\n\n            // Clearing zoom out\n            zoomDeeper.to('#clearing', {\n                scale: 2,\n                opacity: 0,\n                duration: 2.5,\n                ease: 'power2.inOut',\n                pointerEvents: 'none'\n            });\n\n            // Deep Garden enters\n            zoomDeeper.to('#deep-garden', {\n                opacity: 1,\n                scale: 1,\n                duration: 2.5,\n                ease: 'power2.out'\n            }, '-=2');\n\n            // Final message drop using Anime.js (via motion)\n            zoomDeeper.add(() => {\n                animate('#message-2', { \n                    y: ['-60vh', '0vh'],\n                    rotate: [-15, 0]\n                }, { \n                    type: \"spring\", \n                    stiffness: 70, \n                    damping: 10, \n                    mass: 2 \n                });\n            }, '-=0.5');\n        });\n\n    </script>\n    \n    \n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"56\">\n</div>\n",
