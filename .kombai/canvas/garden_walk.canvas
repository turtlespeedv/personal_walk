  "nodes": {
    "var_89c8a624d0ff": {
      "type": "variant",
      "label": "Watercolor Garden Walk (Vertical)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 0,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600&family=Nunito+Sans:wght@300;400;600&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-fredoka { font-family: 'Fredoka', sans-serif; }\n\n    /* Rain Effect - Subtle and integrated */\n    .rain-container {\n        pointer-events: none;\n        position: fixed;\n        inset: 0;\n        z-index: 50;\n        overflow: hidden;\n        opacity: 0.6;\n    }\n    .drop {\n        position: absolute;\n        background: linear-gradient(to bottom, transparent, rgba(123, 160, 91, 0.15), rgba(224, 176, 255, 0.3));\n        width: 1.2px;\n        height: 150px;\n        top: -150px;\n    }\n\n    /* Organic Text Framing */\n    .painterly-frame {\n        background: radial-gradient(circle at center, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.5) 70%, transparent 100%);\n        backdrop-filter: blur(8px);\n        padding: 3rem;\n        border-radius: 60px 20px 80px 40px; /* Asymmetrical */\n    }\n\n    /* Seamless walk transitions */\n    .scene-section {\n        position: relative;\n        width: 100%;\n        min-height: 100vh;\n        display: flex;\n        align-items: center;\n        overflow: hidden;\n    }\n\n    .bg-painterly {\n        position: absolute;\n        inset: 0;\n        z-index: 0;\n    }\n    .bg-painterly img {\n        width: 100%;\n        height: 120%; /* For parallax movement */\n        object-fit: cover;\n    }\n\n    .vignette {\n        position: absolute;\n        inset: 0;\n        background: radial-gradient(circle at center, transparent 40%, rgba(248, 244, 255, 0.4) 100%);\n        pointer-events: none;\n    }\n\n    /* Custom UI Components */\n    .audio-pill {\n        background: rgba(255, 255, 255, 0.6);\n        backdrop-filter: blur(12px);\n        border: 1px solid rgba(255, 255, 255, 0.4);\n        padding: 0.75rem 1.25rem;\n        border-radius: 100px;\n        font-family: 'Fredoka', sans-serif;\n        font-size: 0.875rem;\n        display: flex;\n        align-items: center;\n        gap: 0.5rem;\n        color: #36454F;\n        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);\n    }\n\n    /* Remove Scrollbar but keep functionality */\n    html {\n        scrollbar-width: none;\n        -ms-overflow-style: none;\n    }\n    html::-webkit-scrollbar {\n        display: none;\n    }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n\n<div id=\"smooth-wrapper\" class=\"bg-[#F8F4FF]\" data-kid=\"2\">\n    <div id=\"smooth-content\" data-kid=\"3\">\n        \n        \n        <section id=\"hero\" class=\"scene-section h-screen px-8 md:px-24\" data-kid=\"4\">\n            <div class=\"bg-painterly\" data-kid=\"5\">\n                <img src=\"https://images.unsplash.com/photo-1776286287707-32c03b3691da?auto=format&w=1600&q=80&fit=crop\" alt=\"Watercolor Garden Path\" decoding=\"async\" loading=\"lazy\" class=\"parallax-bg\" data-kid=\"6\">\n                <div class=\"absolute inset-0 bg-gradient-to-b from-[#F8F4FF]/10 via-transparent to-[#F8F4FF]/60\" data-kid=\"7\"></div>\n                <div class=\"vignette\" data-kid=\"8\"></div>\n            </div>\n\n            <div class=\"relative z-10 max-w-4xl pt-24\" data-kid=\"9\">\n                <h1 id=\"hero-title\" class=\"font-fredoka text-7xl md:text-9xl text-[#36454F] leading-[0.9] drop-shadow-sm mb-12\" data-kid=\"10\">\n                    come for <br data-kid=\"11\">\n                    <span class=\"text-[#7BA05B]\" data-kid=\"12\">a walk</span>\n                </h1>\n                <div id=\"hero-sub\" class=\"max-w-md ml-2 space-y-6\" data-kid=\"13\">\n                    <p class=\"text-xl md:text-2xl text-[#36454F]/80 leading-relaxed font-light italic\" data-kid=\"14\">\n                        The garden is quiet today. The rain has washed away the noise of the world, leaving only whispers and dew.\n                    </p>\n                    <div id=\"begin-btn\" class=\"flex items-center gap-4 text-[#7BA05B] font-fredoka font-medium group cursor-pointer\" data-kid=\"15\">\n                        <span class=\"border-b-2 border-transparent group-hover:border-[#7BA05B] transition-all duration-300\" data-kid=\"16\">Begin the journey</span>\n                        <i class=\"ti ti-arrow-right-tail text-2xl animate-pulse\" data-kid=\"17\"></i>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section id=\"stop1\" class=\"scene-section min-h-[120vh] px-8 md:px-24\" data-kid=\"18\">\n            <div class=\"bg-painterly\" data-kid=\"19\">\n                <img src=\"https://images.unsplash.com/photo-1745761500122-a39a7919ec5b?auto=format&w=1600&q=80&fit=crop\" alt=\"Winding Path\" decoding=\"async\" loading=\"lazy\" class=\"parallax-bg\" data-kid=\"20\">\n                <div class=\"absolute inset-0 bg-gradient-to-t from-[#F8F4FF] via-transparent to-[#F8F4FF]\" data-kid=\"21\"></div>\n            </div>\n\n            <div class=\"relative z-10 w-full flex justify-end items-center py-48\" data-kid=\"22\">\n                <div id=\"card1\" class=\"painterly-frame max-w-xl group cursor-pointer\" data-kid=\"23\">\n                    <h2 class=\"font-fredoka text-4xl text-[#7BA05B] mb-6\" data-kid=\"24\">Listen to the leaves</h2>\n                    <p class=\"text-xl md:text-2xl leading-relaxed text-[#36454F] font-normal mb-10\" data-kid=\"25\">\n                        The world slows down here. Each raindrop is a note in a symphony only the garden knows how to play. Can you hear the rhythm of the wind?\n                    </p>\n                    <div class=\"flex items-center gap-4 text-[#36454F] font-fredoka font-medium text-lg opacity-60 group-hover:opacity-100 transition-opacity\" data-kid=\"26\">\n                        <span class=\"border-b border-[#36454F]/20\" data-kid=\"27\">Step further into the mist</span>\n                        <i class=\"ti ti-arrow-right\" data-kid=\"28\"></i>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section id=\"stop2\" class=\"scene-section min-h-[120vh] px-8 md:px-24\" data-kid=\"29\">\n            <div class=\"bg-painterly\" data-kid=\"30\">\n                <img src=\"https://images.unsplash.com/photo-1774885798145-f17c3085ec19?auto=format&w=1600&q=80&fit=crop\" alt=\"Garden Gate\" decoding=\"async\" loading=\"lazy\" class=\"parallax-bg\" data-kid=\"31\">\n                <div class=\"absolute inset-0 bg-gradient-to-t from-transparent via-[#F8F4FF]/40 to-[#F8F4FF]\" data-kid=\"32\"></div>\n            </div>\n\n            <div class=\"relative z-10 w-full flex justify-start items-center py-48\" data-kid=\"33\">\n                <div id=\"card2\" class=\"painterly-frame max-w-xl group cursor-pointer\" data-kid=\"34\">\n                    <h2 class=\"font-fredoka text-4xl text-[#7BA05B] mb-6\" data-kid=\"35\">Deeper into the mist</h2>\n                    <p class=\"text-xl md:text-2xl leading-relaxed text-[#36454F] font-normal mb-10\" data-kid=\"36\">\n                        Notice how the mauve shadows dance between the stems. The garden is breathing, and so are you. This path doesn't lead to a destination, but a state of mind.\n                    </p>\n                    <div class=\"flex items-center gap-4 text-[#36454F] font-fredoka font-medium text-lg opacity-60 group-hover:opacity-100 transition-opacity\" data-kid=\"37\">\n                        <span class=\"border-b border-[#36454F]/20\" data-kid=\"38\">Rest for a while</span>\n                        <i class=\"ti ti-leaf text-[#7BA05B]\" data-kid=\"39\"></i>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section id=\"end\" class=\"scene-section min-h-[80vh] flex flex-col items-center justify-center text-center px-8\" data-kid=\"40\">\n            <div class=\"bg-painterly\" data-kid=\"41\">\n                <img src=\"https://images.pexels.com/photos/8749133/pexels-photo-8749133.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80\" alt=\"Watercolor Wash\" decoding=\"async\" loading=\"lazy\" data-kid=\"42\">\n                <div class=\"absolute inset-0 bg-[#F8F4FF]/40 backdrop-blur-sm\" data-kid=\"43\"></div>\n            </div>\n\n            <div class=\"relative z-10 space-y-8\" data-kid=\"44\">\n                <i class=\"ti ti-flower text-6xl text-[#7BA05B] animate-pulse\" data-kid=\"45\"></i>\n                <h2 class=\"font-fredoka text-5xl md:text-6xl text-[#36454F]\" data-kid=\"46\">Stay as long as you need.</h2>\n                <p class=\"text-xl text-[#36454F]/70 font-light max-w-lg mx-auto\" data-kid=\"47\">\n                    The rain will always be here, and the garden will always welcome you back.\n                </p>\n                <button id=\"restart-btn\" class=\"mt-8 font-fredoka text-[#7BA05B] hover:text-[#36454F] transition-colors uppercase tracking-widest text-sm flex items-center gap-2 mx-auto\" data-kid=\"48\">\n                    <i class=\"ti ti-arrow-up\" data-kid=\"49\"></i> Back to the start\n                </button>\n            </div>\n        </section>\n\n        <footer class=\"relative w-full py-12 px-8 flex flex-col md:flex-row items-center justify-between gap-6 border-t border-[#7BA05B]/10 z-20 bg-[#F8F4FF]\" data-kid=\"50\">\n            <div class=\"flex items-center gap-3\" data-kid=\"51\">\n                <span class=\"font-fredoka text-xl text-[#36454F]\" data-kid=\"52\">Watercolor Garden Walk</span>\n            </div>\n            <div class=\"text-[#36454F]/40 text-sm\" data-kid=\"53\">\n                &copy; 2024 Crafted with peace.\n            </div>\n        </footer>\n    </div>\n</div>\n\n\n<div class=\"rain-container\" id=\"rain-layer\" data-kid=\"54\"></div>\n\n<div class=\"fixed top-8 left-8 z-50\" data-kid=\"55\">\n    <div class=\"audio-pill\" data-kid=\"56\">\n        <i class=\"ti ti-volume-2\" data-kid=\"57\"></i>\n        <span data-kid=\"58\">Sound of Rain</span>\n        <div class=\"flex gap-0.5 items-end h-3\" data-kid=\"59\">\n            <div class=\"w-0.5 h-1 bg-[#7BA05B] animate-bounce\" data-kid=\"60\"></div>\n            <div class=\"w-0.5 h-3 bg-[#7BA05B] animate-bounce\" style=\"animation-delay: 0.1s\" data-kid=\"61\"></div>\n            <div class=\"w-0.5 h-2 bg-[#7BA05B] animate-bounce\" style=\"animation-delay: 0.2s\" data-kid=\"62\"></div>\n        </div>\n    </div>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"63\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"64\"></script>\n<script type=\"module\" data-kid=\"65\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initialize Lenis\n    const lenis = new Lenis({\n        duration: 2.2,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n        smoothWheel: true,\n        orientation: 'vertical',\n    });\n\n    window.lenis = lenis;\n\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    // GSAP Ticker synchronization\n    gsap.ticker.add((time) => {\n        lenis.raf(time * 1000);\n    });\n    gsap.ticker.lagSmoothing(0);\n\n    // Rain generation\n    const rainContainer = document.getElementById('rain-layer');\n    const dropCount = 90;\n    for (let i = 0; i < dropCount; i++) {\n        const drop = document.createElement('div');\n        drop.className = 'drop';\n        drop.style.left = `${Math.random() * 100}%`;\n        const duration = Math.random() * 0.4 + 0.6;\n        const delay = Math.random() * 2;\n        rainContainer.appendChild(drop);\n        \n        gsap.to(drop, {\n            y: window.innerHeight + 200,\n            duration: duration,\n            delay: delay,\n            repeat: -1,\n            ease: \"none\"\n        });\n    }\n\n    // --- Entrance Animations ---\n\n    // Hero\n    gsap.from(\"#hero-title\", {\n        autoAlpha: 0,\n        x: -50,\n        duration: 1.8,\n        ease: \"power4.out\"\n    });\n\n    gsap.from(\"#hero-sub\", {\n        autoAlpha: 0,\n        y: 30,\n        duration: 1.5,\n        delay: 0.5,\n        ease: \"power3.out\"\n    });\n\n    // Auto-scroll interaction (5s after load)\n    const autoScrollTimeout = setTimeout(() => {\n        if (window.scrollY < 50) {\n            lenis.scrollTo('#stop1', {\n                duration: 4,\n                easing: (t) => t === 1 ? 1 : 1 - Math.pow(2, -10 * t)\n            });\n        }\n    }, 5000);\n\n    // Prevent auto-scroll if user interacts\n    window.addEventListener('wheel', () => clearTimeout(autoScrollTimeout), { once: true });\n    window.addEventListener('touchstart', () => clearTimeout(autoScrollTimeout), { once: true });\n\n    // Scene Reveals\n    gsap.from(\"#card1\", {\n        scrollTrigger: {\n            trigger: \"#stop1\",\n            start: \"top 60%\",\n        },\n        autoAlpha: 0,\n        x: 60,\n        duration: 1.5,\n        ease: \"power3.out\"\n    });\n\n    gsap.from(\"#card2\", {\n        scrollTrigger: {\n            trigger: \"#stop2\",\n            start: \"top 60%\",\n        },\n        autoAlpha: 0,\n        x: -60,\n        duration: 1.5,\n        ease: \"power3.out\"\n    });\n\n    // Interaction Handlers\n    document.getElementById('begin-btn').addEventListener('click', () => {\n        lenis.scrollTo('#stop1', { duration: 2 });\n    });\n\n    document.getElementById('restart-btn').addEventListener('click', () => {\n        lenis.scrollTo('#hero', { duration: 3 });\n    });\n\n    // Card Transitions (Manual Hover with GSAP)\n    const painterlyFrames = document.querySelectorAll('.painterly-frame');\n    painterlyFrames.forEach(frame => {\n        frame.addEventListener('pointerenter', () => {\n            gsap.to(frame, {\n                y: -12,\n                scale: 1.01,\n                boxShadow: \"0 20px 40px rgba(0,0,0,0.03)\",\n                duration: 0.8,\n                ease: \"power2.out\"\n            });\n        });\n        frame.addEventListener('pointerleave', () => {\n            gsap.to(frame, {\n                y: 0,\n                scale: 1,\n                boxShadow: \"0 0px 0px rgba(0,0,0,0)\",\n                duration: 0.8,\n                ease: \"power2.out\"\n            });\n        });\n        frame.addEventListener('click', () => {\n            const nextId = frame.id === 'card1' ? '#stop2' : '#end';\n            lenis.scrollTo(nextId, { duration: 2.2 });\n        });\n    });\n\n    // Parallax Effect on Backgrounds\n    const parallaxes = document.querySelectorAll('.parallax-bg');\n    parallaxes.forEach(img => {\n        gsap.to(img, {\n            yPercent: 15,\n            ease: \"none\",\n            scrollTrigger: {\n                trigger: img.closest('.scene-section'),\n                start: \"top bottom\",\n                end: \"bottom top\",\n                scrub: 1\n            }\n        });\n    });\n\n</script>",
      "comments": [],
      "created": "2026-06-13T17:01:25.190646+00:00",
      "modified": "2026-06-13T17:01:25.190646+00:00",
