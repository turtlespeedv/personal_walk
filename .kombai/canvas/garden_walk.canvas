    "var_35e2baabb5ea": {
      "type": "variant",
      "label": "Horizontal Garden Path",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 2760,
        "y": 0,
        "w": 1440,
        "h": 800
