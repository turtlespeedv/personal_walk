      "html": "\n<div id=\"garden-walk\" class=\"h-screen w-full bg-[#FFFDD0] overflow-hidden font-['Quicksand'] text-[#8A9A5B] selection:bg-[#FAD6A5] selection:text-[#8A9A5B]\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Lora:wght@400;700&family=Quicksand:wght@300;400;600&display=swap');\n\n        /* Custom scrollbar for horizontal - though Locomotive might hide it */\n        #main-container::-webkit-scrollbar {\n            display: none;\n        }\n        #main-container {\n            -ms-overflow-style: none;\n            scrollbar-width: none;\n        }\n\n        .hanging-sign {\n            transform-origin: top center;\n        }\n\n        .rope {\n            width: 2px;\n            background: repeating-linear-gradient(\n                to bottom,\n                #5c693a,\n                #5c693a 4px,\n                #4a542e 4px,\n                #4a542e 8px\n            );\n            box-shadow: 1px 1px 3px rgba(0,0,0,0.2);\n        }\n\n        .rain-particle {\n            position: absolute;\n            background: rgba(255, 255, 255, 0.4);\n            width: 1px;\n            height: 20px;\n            pointer-events: none;\n            z-index: 50;\n        }\n\n        .wall-texture {\n            background-image: url(\"https://www.transparenttextures.com/patterns/brick-wall.png\");\n        }\n\n        .stone-plaque {\n            box-shadow: inset 0 0 15px rgba(0,0,0,0.1), 8px 8px 24px rgba(0,0,0,0.15);\n        }\n\n        .ivy-vine {\n            filter: drop-shadow(0 4px 4px rgba(0,0,0,0.05));\n            transition: transform 0.3s ease-out;\n        }\n        .ivy-vine:hover {\n            transform: scale(1.1) rotate(5deg);\n        }\n\n        /* Locomotive v5 specific tweaks if needed */\n        [data-scroll-container] {\n            display: flex;\n            width: 300vw;\n        }\n\n        .section-panel {\n            width: 100vw;\n            height: 100vh;\n            flex-shrink: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            position: relative;\n        }\n    </style>\n\n    \n    <div id=\"rain-field\" class=\"fixed inset-0 pointer-events-none overflow-hidden z-[100]\" data-kid=\"2\"></div>\n\n    \n    <div class=\"fixed top-0 left-0 h-full w-[300vw] wall-texture opacity-5 pointer-events-none z-0\" data-kid=\"3\"></div>\n\n    \n    <div class=\"fixed bottom-8 left-1/2 -translate-x-1/2 z-[110] flex items-center gap-4 bg-[#FAD6A5] px-6 py-3 rounded-full border-2 border-[#8A9A5B]/40 shadow-[0_8px_30px_rgb(138,154,91,0.2)]\" id=\"audio-dock\" data-kid=\"4\">\n        <button id=\"audio-toggle\" class=\"w-10 h-10 rounded-full bg-[#8A9A5B] flex items-center justify-center text-[#FAD6A5] hover:scale-110 transition-transform cursor-pointer\" data-kid=\"5\">\n            <i class=\"fa-solid fa-play\" id=\"audio-icon\" data-kid=\"6\"></i>\n        </button>\n        <div class=\"flex flex-col\" data-kid=\"7\">\n            <span class=\"text-[10px] font-bold uppercase tracking-widest text-[#8A9A5B] opacity-80\" data-kid=\"8\">Garden Melodies</span>\n            <span class=\"text-xs font-semibold text-[#5c693a]\" data-kid=\"9\">Morning Rain Ambience</span>\n        </div>\n        <div class=\"flex gap-1 ml-2 h-4 items-end\" id=\"audio-visualizer\" data-kid=\"10\">\n            <div class=\"w-1 h-full bg-[#8A9A5B]/40 rounded-full visualizer-bar\" data-kid=\"11\"></div>\n            <div class=\"w-1 h-1/2 bg-[#8A9A5B]/40 rounded-full visualizer-bar\" data-kid=\"12\"></div>\n            <div class=\"w-1 h-3/4 bg-[#8A9A5B]/40 rounded-full visualizer-bar\" data-kid=\"13\"></div>\n            <div class=\"w-1 h-2/3 bg-[#8A9A5B]/40 rounded-full visualizer-bar\" data-kid=\"14\"></div>\n        </div>\n    </div>\n\n    \n    <main id=\"main-container\" data-scroll-container class=\"flex h-full w-full overflow-x-auto overflow-y-hidden bg-[#FFFDD0]\" data-kid=\"15\">\n        \n        \n        <section id=\"hero\" class=\"section-panel bg-[#FFFDD0]\" data-scroll-section data-kid=\"16\">\n            <div class=\"absolute inset-0 z-0\" data-kid=\"17\">\n                <img src=\"https://images.unsplash.com/photo-1625730969972-3ae6b19761d6?auto=format&w=1920&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-60 grayscale-[10%]\" alt=\"Ornate Garden Gate\" data-kid=\"18\">\n                <div class=\"absolute inset-0 bg-gradient-to-r from-[#FFFDD0] via-[#FFFDD0]/40 to-transparent\" data-kid=\"19\"></div>\n            </div>\n\n            <div class=\"relative z-10 w-full max-w-6xl px-12 flex flex-col items-start\" data-kid=\"20\">\n                <div id=\"sign-wrapper\" class=\"hanging-sign mb-12 ml-4\" data-kid=\"21\">\n                    \n                    <div class=\"flex justify-between w-80 px-12 mb-[-6px]\" data-kid=\"22\">\n                        <div class=\"rope h-24\" data-kid=\"23\"></div>\n                        <div class=\"rope h-24\" data-kid=\"24\"></div>\n                    </div>\n                    \n                    <div class=\"bg-[#FAD6A5] px-14 py-10 border-4 border-[#8A9A5B] shadow-2xl rounded-[4px] relative transform -rotate-1\" data-kid=\"25\">\n                        <h1 class=\"font-['Lora'] text-5xl md:text-7xl text-[#8A9A5B] font-bold tracking-tight\" data-kid=\"26\">Come for a walk</h1>\n                        <div class=\"absolute -top-2 -right-4 hover:scale-125 transition-transform duration-500\" data-kid=\"27\">\n                            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/leaf-fluttering-in-wind.svg\" class=\"w-12 h-12 rotate-[15deg]\" data-kid=\"28\">\n                        </div>\n                    </div>\n                </div>\n                <div class=\"bg-white/50 backdrop-blur-md p-8 rounded-2xl border border-white/60 max-w-xl shadow-sm\" data-kid=\"29\">\n                    <p class=\"text-xl md:text-3xl text-[#5c693a] leading-relaxed font-semibold font-['Lora'] italic\" data-kid=\"30\">\n                        The rain is gentle, the morning is quiet. Let's find some beauty along the old garden wall.\n                    </p>\n                </div>\n                \n                <div class=\"mt-16 flex items-center gap-4 text-sm font-bold uppercase tracking-[0.3em] text-[#8A9A5B] opacity-80\" data-kid=\"31\">\n                    <span class=\"instruction-fade\" data-kid=\"32\">Wait a moment</span>\n                    <div class=\"w-16 h-[1.5px] bg-[#8A9A5B]/30\" data-kid=\"33\"></div>\n                    <span class=\"instruction-fade\" data-kid=\"34\">or scroll sideways</span>\n                </div>\n            </div>\n\n            <style data-kid=\"35\">\n                @keyframes softFade {\n                    0%, 100% { opacity: 0.4; }\n                    50% { opacity: 1; }\n                }\n                .instruction-fade {\n                    animation: softFade 3s ease-in-out infinite;\n                }\n            </style>\n        </section>\n\n        \n        <section id=\"stop-1\" class=\"section-panel bg-[#D0F0C0]\" data-scroll-section data-kid=\"36\">\n            <div class=\"absolute inset-0 opacity-10 pointer-events-none flex items-center justify-center overflow-hidden\" data-kid=\"37\">\n                <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/leaf-fluttering-in-wind.svg\" class=\"w-[80vw] h-[80vw] blur-3xl opacity-20\" data-kid=\"38\">\n            </div>\n            \n            <div class=\"relative z-10 max-w-3xl w-full px-12\" data-kid=\"39\">\n                <div id=\"plaque-trigger\" class=\"stone-plaque bg-[#E5E7EB] rounded-sm p-16 md:p-24 relative overflow-hidden cursor-pointer group\" data-kid=\"40\">\n                    \n                    <div class=\"absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/granite.png')] opacity-30 pointer-events-none\" data-kid=\"41\"></div>\n                    \n                    <div class=\"relative z-10 text-center space-y-8\" data-kid=\"42\">\n                        <div class=\"inline-block px-4 py-1 rounded-full border border-gray-400 text-xs font-bold uppercase tracking-widest text-gray-500 mb-4\" data-kid=\"43\">A message in stone</div>\n                        <h2 class=\"font-['Lora'] text-3xl md:text-5xl text-gray-700 italic leading-tight\" data-kid=\"44\">\n                            \"Nature does not hurry, yet everything is accomplished.\"\n                        </h2>\n                        <div class=\"pt-12\" data-kid=\"45\">\n                            <button id=\"continue-btn\" class=\"px-8 py-3 rounded-full bg-[#8A9A5B] text-white font-bold uppercase tracking-widest text-xs shadow-lg group-hover:scale-110 transition-transform\" data-kid=\"46\">\n                                Click to continue walk\n                            </button>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"absolute -bottom-8 -left-8 w-48 h-48 opacity-60 rotate-[-15deg] ivy-vine\" data-kid=\"47\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/leaf-fluttering-in-wind.svg\" class=\"w-full h-full\" data-kid=\"48\">\n                    </div>\n                    <div class=\"absolute -top-12 -right-12 w-32 h-32 opacity-40 rotate-[160deg] ivy-vine\" data-kid=\"49\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/leaf-fluttering-in-wind.svg\" class=\"w-full h-full\" data-kid=\"50\">\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section id=\"stop-2\" class=\"section-panel bg-[#FFFDD0]\" data-scroll-section data-kid=\"51\">\n            <div class=\"relative z-10 max-w-7xl w-full px-12 grid grid-cols-1 md:grid-cols-2 gap-16 items-center\" data-kid=\"52\">\n                <div class=\"relative\" data-kid=\"53\">\n                    <div class=\"absolute -inset-4 border-2 border-[#8A9A5B]/20 rounded-[2.5rem]\" data-kid=\"54\"></div>\n                    <div class=\"rounded-[2rem] overflow-hidden shadow-2xl relative z-10 aspect-[4/5] md:aspect-square\" data-kid=\"55\">\n                        <img src=\"https://images.unsplash.com/photo-1638348057205-bace6c7d9c5c?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Wooden Park Bench\" data-kid=\"56\">\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-[#8A9A5B]/40 to-transparent\" data-kid=\"57\"></div>\n                    </div>\n                    \n                    <div class=\"absolute -top-12 -right-12 w-24 h-24 animate-bounce duration-[3000ms]\" data-kid=\"58\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/leaf-fluttering-in-wind.svg\" class=\"w-full h-full\" data-kid=\"59\">\n                    </div>\n                </div>\n\n                <div class=\"space-y-8\" data-kid=\"60\">\n                    <div class=\"space-y-2\" data-kid=\"61\">\n                        <span class=\"text-[#FAD6A5] font-bold text-sm uppercase tracking-[0.3em]\" data-kid=\"62\">Rest Stop</span>\n                        <h2 class=\"font-['Lora'] text-5xl md:text-7xl text-[#8A9A5B] font-bold\" data-kid=\"63\">The Hidden Bench</h2>\n                    </div>\n                    <div class=\"w-24 h-1.5 bg-[#FAD6A5]\" data-kid=\"64\"></div>\n                    <div class=\"space-y-6\" data-kid=\"65\">\n                        <p class=\"font-['Lora'] text-2xl md:text-3xl text-[#8A9A5B]/90 italic leading-relaxed\" data-kid=\"66\">\n                            \"In every walk with nature, one receives far more than he seeks.\"\n                        </p>\n                        <div class=\"flex items-center gap-4\" data-kid=\"67\">\n                            <div class=\"w-8 h-[1px] bg-[#8A9A5B]/40\" data-kid=\"68\"></div>\n                            <p class=\"text-lg font-semibold text-[#8A9A5B]/60 tracking-wider uppercase\" data-kid=\"69\">— John Muir</p>\n                        </div>\n                    </div>\n                    <div class=\"pt-8\" data-kid=\"70\">\n                        <button onclick=\"scrollToSection('#hero')\" class=\"flex items-center gap-4 text-[#8A9A5B] group cursor-pointer\" data-kid=\"71\">\n                            <span class=\"w-12 h-12 rounded-full border-2 border-[#8A9A5B] flex items-center justify-center group-hover:bg-[#8A9A5B] group-hover:text-white transition-all duration-500 shadow-sm\" data-kid=\"72\">\n                                <i class=\"fa-solid fa-rotate-left\" data-kid=\"73\"></i>\n                            </span>\n                            <span class=\"font-bold uppercase tracking-widest text-xs border-b border-transparent group-hover:border-[#8A9A5B] transition-all\" data-kid=\"74\">Return to start</span>\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n    </main>\n\n    \n    <script src=\"https://kit.fontawesome.com/a076d05399.js\" crossorigin=\"anonymous\" data-kid=\"75\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" data-kid=\"76\">\n    \n    \n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css\" data-kid=\"77\">\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"78\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"79\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"80\"></script>\n    \n    <script type=\"module\" data-kid=\"81\">\n        import { animate as motionAnimate, press } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n        import { animate as animeAnimate } from \"https://esm.sh/animejs@4\"\n\n        // Initialize GSAP\n        gsap.registerPlugin(ScrollTrigger);\n\n        // Initialize Locomotive Scroll v5\n        const scroll = new LocomotiveScroll({\n            lenisOptions: {\n                wrapper: document.querySelector('#main-container'),\n                content: document.querySelector('[data-scroll-container]'),\n                lerp: 0.1,\n                duration: 1.2,\n                orientation: 'horizontal',\n                gestureOrientation: 'both',\n                smoothWheel: true\n            }\n        });\n\n        // 1. Rain Particles Animation (Anime.js v4 syntax)\n        const rainContainer = document.querySelector('#rain-field');\n        function createRain() {\n            const drop = document.createElement('div');\n            drop.className = 'rain-particle';\n            drop.style.left = Math.random() * 100 + 'vw';\n            drop.style.top = '-20px';\n            drop.style.opacity = Math.random() * 0.3 + 0.1;\n            rainContainer.appendChild(drop);\n\n            animeAnimate(drop, {\n                y: '105vh',\n                x: (Math.random() - 0.5) * 120,\n                duration: 1500 + Math.random() * 1000,\n                ease: 'linear',\n                onComplete: () => drop.remove()\n            });\n        }\n        setInterval(createRain, 40);\n\n        // 2. Hanging Sign Swing (GSAP)\n        gsap.to('.hanging-sign', {\n            rotation: 2,\n            duration: 3,\n            ease: 'sine.inOut',\n            repeat: -1,\n            yoyo: true,\n            transformOrigin: 'top center'\n        });\n\n        // 3. Auto-scroll to Stop 1 after 5 seconds\n        setTimeout(() => {\n            const stop1 = document.querySelector('#stop-1');\n            scroll.scrollTo(stop1, {\n                duration: 2.5,\n                immediate: false\n            });\n        }, 5000);\n\n        // 4. Interaction: Click Plaque to continue\n        const plaque = document.querySelector('#plaque-trigger');\n        \n        press(plaque, el => {\n            motionAnimate(el, { scale: 0.96 });\n            return () => {\n                motionAnimate(el, { scale: 1 });\n                const stop2 = document.querySelector('#stop-2');\n                scroll.scrollTo(stop2, { duration: 2.5 });\n            };\n        });\n\n        // 5. Audio Player Logic\n        let isPlaying = false;\n        const audioBtn = document.querySelector('#audio-toggle');\n        const audioIcon = document.querySelector('#audio-icon');\n        const visualizerBars = document.querySelectorAll('.visualizer-bar');\n\n        audioBtn.onclick = () => {\n            isPlaying = !isPlaying;\n            audioIcon.className = isPlaying ? 'fa-solid fa-pause' : 'fa-solid fa-play';\n            \n            if (isPlaying) {\n                visualizerBars.forEach((bar, i) => {\n                    animeAnimate(bar, {\n                        height: ['20%', '100%'],\n                        duration: 600 + (i * 150),\n                        alternate: true,\n                        loop: true,\n                        ease: 'easeInOutSine'\n                    });\n                });\n            } else {\n                visualizerBars.forEach(bar => {\n                    animeAnimate(bar, { \n                        height: '30%', \n                        duration: 400, \n                        loop: false,\n                        ease: 'easeOutQuad'\n                    });\n                });\n            }\n        };\n\n        // Internal scroll function for links\n        window.scrollToSection = (selector) => {\n            const target = document.querySelector(selector);\n            if (target) {\n                scroll.scrollTo(target, {\n                    duration: 2.5,\n                    immediate: false\n                });\n            }\n        };\n\n        // Entrance animations for content\n        gsap.from('#hero h1', {\n            y: 50,\n            opacity: 0,\n            duration: 1.5,\n            delay: 0.5,\n            ease: 'power3.out'\n        });\n\n    </script>\n</div>\n",
